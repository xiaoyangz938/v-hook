GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# Optional: enable free cloud-backed community storage with Supabase.
# If SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are not set,
# the app falls back to the current local file/data storage.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="community-assets"

# Public website safety switch.
# Keep false for a public showcase site.
VHOOK_ENABLE_PUBLIC_UPLOADS="false"
VHOOK_ADMIN_PASSWORD="change-this-admin-password"
